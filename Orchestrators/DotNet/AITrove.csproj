<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>AITrove</RootNamespace>
    <AssemblyName>AITrove.Orchestrators.DotNet</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <!-- Anthropic .NET SDK (community) -->
    <PackageReference Include="Anthropic.SDK" Version="3.*" />

    <!-- DI + hosting + logging -->
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="9.*" />
    <PackageReference Include="Microsoft.Extensions.Hosting"             Version="9.*" />
    <PackageReference Include="Microsoft.Extensions.Logging.Console"     Version="9.*" />
  </ItemGroup>

  <ItemGroup>
    <!-- Embed prompt files so they're available next to the binary -->
    <Content Include="..\..\Prompts\**\*"
             CopyToOutputDirectory="PreserveNewest"
             LinkBase="Prompts" />
  </ItemGroup>

</Project>
